{
    "name": "mongoresolve-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "MongoDB Query parser and custom resolver",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "format": "prettier --write \"packages/**/*.{ts,js,json,md}\"",
        "format:check": "prettier --check \"packages/**/*.{ts,js,json,md}\""
    },
    "keywords": [
        "mongodb",
        "query",
        "parser",
        "resolver"
    ],
    "author": "bccsa",
    "license": "MIT",
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.19",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "ts-jest": "^29.1.2",
        "typescript": "^5.3.3"
    }
}
